{% template status_badge %}
  {% if status == 1 %}
    <span class="label label--small label--filled">Low</span>
  {% elsif status == 2 %}
    <span class="label label--small label--outline">Low</span>
  {% elsif status == 4 %}
    <span class="label label--small label--outline">High</span>
  {% elsif status == 5 %}
    <span class="label label--small label--filled">High</span>
  {% else %}
    <span class="label label--small">OK</span>
  {% endif %}
{% endtemplate %}

{% assign plant = plants | first %}

<div class="view view--quadrant">
  <div class="layout layout--center">
    {% if plant %}
      <div class="flex flex--col gap--small">
        <div class="flex flex--row gap--small">
          <img
            class="image image-dither image--cover rounded w--14 h--14"
            src="{{ plant.thumb_path }}"
            alt="{{ plant.nickname }}"
          >
          <div class="flex flex--col gap--none">
            <span class="title title--small" data-clamp="1">{{ plant.nickname }}</span>
            <span class="label label--small label--gray" data-clamp="1">{{ plant.scientific_name }}</span>
          </div>
        </div>
        <div class="grid grid--cols-4 gap--xsmall">
          <div class="col col--center">
            <span class="label label--small label--gray">Water</span>
            {% render 'status_badge', status: plant.moisture_status %}
          </div>
          <div class="col col--center">
            <span class="label label--small label--gray">Light</span>
            {% render 'status_badge', status: plant.light_status %}
          </div>
          <div class="col col--center">
            <span class="label label--small label--gray">Temp</span>
            {% render 'status_badge', status: plant.temperature_status %}
          </div>
          <div class="col col--center">
            <span class="label label--small label--gray">Salt</span>
            {% render 'status_badge', status: plant.salinity_status %}
          </div>
        </div>
      </div>
    {% else %}
      <span class="title title--small">No plants found</span>
    {% endif %}
  </div>
  <div class="title_bar">
    <span class="title">FYTA</span>
  </div>
</div>
