{% template status_badge %}
  {% if status == 1 %}
    <span class="label label--filled">Low</span>
  {% elsif status == 2 %}
    <span class="label label--outline">Low</span>
  {% elsif status == 4 %}
    <span class="label label--outline">High</span>
  {% elsif status == 5 %}
    <span class="label label--filled">High</span>
  {% else %}
    <span class="label">OK</span>
  {% endif %}
{% endtemplate %}

<div class="view view--full">
  <div class="layout layout--col gap--large">
    <div class="grid grid--cols-3 gap--medium">
      {% for plant in plants %}
        <div class="col col--center">
          <img
            class="image image-dither image--cover rounded--medium w--full h--32"
            src="{{ plant.thumb_path }}"
            alt="{{ plant.nickname }}"
          >
          <span class="title mt--1" data-clamp="1">{{ plant.nickname }}</span>
          <span class="label label--gray" data-clamp="1">{{ plant.scientific_name }}</span>
        </div>
      {% endfor %}
    </div>

    <table class="table" data-table-limit="true">
      <thead>
        <tr>
          <th><span class="title">Plant</span></th>
          <th><span class="title">Water</span></th>
          <th><span class="title">Light</span></th>
          <th><span class="title">Temp</span></th>
          <th><span class="title">Salt</span></th>
        </tr>
      </thead>
      <tbody>
        {% for plant in plants %}
          <tr>
            <td><span class="label" data-clamp="1">{{ plant.nickname }}</span></td>
            <td>{% render 'status_badge', status: plant.moisture_status %}</td>
            <td>{% render 'status_badge', status: plant.light_status %}</td>
            <td>{% render 'status_badge', status: plant.temperature_status %}</td>
            <td>{% render 'status_badge', status: plant.salinity_status %}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <div class="title_bar">
    <span class="title">FYTA Plants</span>
  </div>
</div>
